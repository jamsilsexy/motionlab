rules_version = '2';

service cloud.firestore {
  // Firestore 문서 경로 규칙의 최상위 범위
  match /databases/{database}/documents {
    // 로그인 여부 확인 헬퍼
    function isSignedIn() {
      return request.auth != null;
    }

    // 관리자 권한 여부 확인 헬퍼
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // 테스터 권한 여부 확인 헬퍼
    function isTester() {
      return isSignedIn() && request.auth.token.tester == true;
    }

    // 요청 사용자가 특정 uid의 소유자인지 확인 헬퍼
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    /* ─────────────────────────────────────────────────────────
       users/{uid} — 사용자 프로필 컬렉션
       서버 전용 필드: plan, analysisCount, analysisResetDate
         → 클라이언트 write 차단 (Cloud Functions만 변경 가능)
         → 결제/사용량 우회 방지의 핵심 라인
       ──────────────────────────────────────────────────────── */
    match /users/{uid} {
      // 본인 또는 admin만 read 가능
      allow read: if isOwner(uid) || isAdmin();

      // 신규 가입: 본인 uid + 필수 필드 + 서버 전용 필드 초기값 강제
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll(['plan', 'analysisCount', 'analysisResetDate', 'createdAt'])
        && request.resource.data.plan == 'free'
        && request.resource.data.analysisCount == 0;

      // update: 본인이되 서버 전용 3개 필드 불변. admin은 자유 변경 가능.
      allow update: if isAdmin() || (
        isOwner(uid)
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.analysisCount == resource.data.analysisCount
        && request.resource.data.analysisResetDate == resource.data.analysisResetDate
      );

      // 본인 회원 탈퇴 또는 admin 강제 삭제
      allow delete: if isOwner(uid) || isAdmin();
    }

    /* ─────────────────────────────────────────────────────────
       members/{ownerUid}/list/{memberId} — 트레이너의 회원 명단
       본인(트레이너 uid) 외 절대 접근 불가
       ──────────────────────────────────────────────────────── */
    match /members/{ownerUid}/list/{memberId} {
      allow read, write: if isOwner(ownerUid) || isAdmin();
    }

    // members/{ownerUid} 자체 문서 (하위 컬렉션의 부모)
    match /members/{ownerUid} {
      allow read, write: if isOwner(ownerUid) || isAdmin();
    }

    // 명시되지 않은 모든 경로에 대한 기본 차단 규칙
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
